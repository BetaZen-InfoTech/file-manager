# ====================================================================
# File Manager SaaS — environment variables
# Copy this file to `.env` and fill in the real values on the VPS.
# NEVER commit `.env` to git.
#
# Generate a secret: openssl rand -hex 32
# ====================================================================

# ---- App ----
NODE_ENV=production
APP_URL=https://files.yourdomain.com
PORT=3000

# ---- Auth ----
JWT_SECRET=replace-with-64-char-random-hex
SESSION_COOKIE_SECRET=replace-with-random-hex
SESSION_COOKIE_NAME=fms_session
SESSION_TTL_HOURS=12

# ---- MongoDB ----
MONGODB_URI=mongodb://fmsuser:strongpass@127.0.0.1:27017/filemanager?authSource=admin

# ---- Storage (MinIO / S3) ----
STORAGE_DRIVER=minio
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadminstrongpass
S3_FORCE_PATH_STYLE=true
S3_USE_SSL=false
S3_DEFAULT_BUCKET=filemanager

# ---- Public URL signing ----
PUBLIC_URL_BASE=https://files.yourdomain.com
PUBLIC_TOKEN_BYTES=24

# ---- Deploy webhook ----
GITHUB_WEBHOOK_SECRET=replace-with-strong-secret
DEPLOY_BRANCH=main
DEPLOY_SCRIPT=/var/www/app/scripts/deploy.sh

# ---- Limits ----
MAX_UPLOAD_BYTES=524288000

# ---- Optional ----
REDIS_URL=redis://127.0.0.1:6379
CLAMAV_HOST=
CLAMAV_PORT=3310

# ---- Mail ----
MAIL_DRIVER=smtp
MAIL_HOST=smtp.yourprovider.com
MAIL_PORT=587
MAIL_USER=postmaster@yourdomain.com
MAIL_PASS=replace-me
MAIL_FROM=File Manager <no-reply@yourdomain.com>

# ---- Internal cron auth ----
INTERNAL_CRON_SECRET=replace-with-random-secret

# ---- Rate limit ----
RATE_LIMIT_PER_MIN=100
