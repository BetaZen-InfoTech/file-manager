# ====================================================================
# File Manager SaaS — environment variables
# Copy this file to `.env` and fill in the real values on the VPS.
# NEVER commit `.env` to git.
#
# Generate a secret: openssl rand -hex 32
# ====================================================================

# ---- App ----
NODE_ENV=production
APP_URL=https://files.yourdomain.com
PORT=3000

# ---- Auth ----
JWT_SECRET=replace-with-64-char-random-hex
SESSION_COOKIE_SECRET=replace-with-random-hex
SESSION_COOKIE_NAME=fms_session
SESSION_TTL_HOURS=12
# Session-cookie Secure flag. Browsers ONLY store Secure cookies over HTTPS, so
# if you serve over plain HTTP (bare IP / no TLS) you MUST set this to false or
# login silently fails (cookie dropped → bounced back to /login). Leave true for
# any HTTPS deployment. Unset → defaults to true in production.
COOKIE_SECURE=true

# ---- MongoDB ----
MONGODB_URI=mongodb://fmsuser:strongpass@127.0.0.1:27017/filemanager?authSource=admin

# ---- Storage ----
# 'disk' (default) = store files on the local filesystem; no S3/MinIO needed.
#   Files land at STORAGE_DISK_ROOT/vendors/<vendorId>/buckets/<bucketId>/<fileId>/<name>
# 's3' / 'minio' = use an S3-compatible object store (set the S3_* values below).
STORAGE_DRIVER=disk
STORAGE_DISK_ROOT=/var/www
# S3_* below are ONLY used when STORAGE_DRIVER=s3/minio, OR for the admin
# "Import from S3" migration source. Safe to leave as-is when using disk storage.
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadminstrongpass
S3_FORCE_PATH_STYLE=true
S3_USE_SSL=false
S3_DEFAULT_BUCKET=filemanager

# ---- Public URL signing ----
PUBLIC_URL_BASE=https://files.yourdomain.com
PUBLIC_TOKEN_BYTES=24

# ---- Deploy webhook ----
GITHUB_WEBHOOK_SECRET=replace-with-strong-secret
DEPLOY_BRANCH=main
DEPLOY_SCRIPT=/var/www/app/scripts/deploy.sh

# ---- Limits ----
MAX_UPLOAD_BYTES=524288000

# ---- Optional ----
REDIS_URL=redis://127.0.0.1:6379
CLAMAV_HOST=
CLAMAV_PORT=3310

# ---- Mail ----
MAIL_DRIVER=smtp
MAIL_HOST=smtp.yourprovider.com
MAIL_PORT=587
MAIL_USER=postmaster@yourdomain.com
MAIL_PASS=replace-me
MAIL_FROM=File Manager <no-reply@yourdomain.com>

# ---- Internal cron auth ----
INTERNAL_CRON_SECRET=replace-with-random-secret

# ---- Rate limit ----
RATE_LIMIT_PER_MIN=100

# ---- Default-login button (DEMO/STAGING ONLY) ----
# When BOTH are set, the /login page shows the credentials and an
# "Autofill & sign in" button. SECURITY: anyone who opens /login can then sign
# in as this account — only enable for demos, and never with a privileged
# production admin. Leave blank to hide the button.
DEMO_LOGIN_EMAIL=
DEMO_LOGIN_PASSWORD=
