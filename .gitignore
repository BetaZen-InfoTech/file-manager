# ── dependencies & build output ──────────────────────────────────────────
node_modules/
.next/
out/
dist/
build/
.turbo/
*.tsbuildinfo
tsconfig.tsbuildinfo

# ── env & secrets (NEVER commit) ─────────────────────────────────────────
.env
.env.*
!.env.example
.env.bak
.env.bak.*
*.pem
*.key
*.crt
# install report contains admin creds + gateway/S3 secrets
file-manager-install-report.txt

# ── logs ─────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
deploy.log
pm2.log
pm2-out.log
pm2-err.log
fms-setup.log
fms-backup.log

# ── package managers ─────────────────────────────────────────────────────
# No lockfile is committed for this repo (installer resolves with `npm install`),
# so ignore all of them to keep the working tree clean and avoid mixing managers.
package-lock.json
npm-shrinkwrap.json
yarn.lock
pnpm-lock.yaml

# ── backups & dumps ──────────────────────────────────────────────────────
*.bak
*.orig
backups/
*.dump
*.gz

# ── os / editor ──────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# ── coverage / cache / test artifacts ────────────────────────────────────
coverage/
.cache/
.eslintcache
playwright-report/
test-results/

# ── next ─────────────────────────────────────────────────────────────────
next-env.d.ts

# ── uploaded local files (when disk driver in use) ───────────────────────
storage_local/

# ── Claude memory directory should never be tracked ──────────────────────
memory/
